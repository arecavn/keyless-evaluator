# Keyless Evaluator — Environment Variables
#
# DEFAULT MODE: Gemini API (free, 1500 req/day, no credit card)
# 1. Get your key at https://aistudio.google.com/apikey
# 2. Paste it below
# 3. Run: uv run keyless-eval eval -q "your query" -f results.json
#
# NO-KEY MODE: Anonymous ChatGPT (silent headless by default — no window shown)
#   uv run keyless-eval eval -q "your query" -f results.json -p chatgpt_web

# ─────────────────────────────────────────────────────────────────
# PRIMARY: Gemini (free quota via Google AI Studio)
# ─────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=AI...

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: Other providers
# ─────────────────────────────────────────────────────────────────

# OpenAI (for: -p openai -m gpt-4o)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (for: -p anthropic -m claude-3-5-haiku-20241022)
# ANTHROPIC_API_KEY=sk-ant-...

# Custom OpenAI-compatible endpoint (Ollama, LiteLLM, Azure, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# ─────────────────────────────────────────────────────────────────
# SERVER / PRODUCTION
# ─────────────────────────────────────────────────────────────────

# CORS allowed origins for the FastAPI server (comma-separated)
# ALLOWED_ORIGINS=https://your-domain.com,https://app.your-domain.com

# chatgpt_web headless mode (default: 1 = silent, no window shown)
# Set to 0 to show the Chrome window (useful for debugging or if headless is blocked)
# CHATGPT_WEB_HEADLESS=1
