# Oracle Search Evaluator — Environment Variables
#
# DEFAULT MODE: Browser (no API key needed)
# Just log into gemini.google.com or chatgpt.com in Chrome and run:
#   oracle-eval eval -q "your query" -f results.json
#
# The Oracle CLI will use your existing browser session automatically.

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: API key fallbacks (only needed if using --engine api)
# ─────────────────────────────────────────────────────────────────

# OpenAI (for: -p openai  OR  -p oracle -e api -m gpt-4o)
# OPENAI_API_KEY=sk-...

# Gemini (for: -p gemini)
# GEMINI_API_KEY=AI...

# Anthropic (for: -p oracle -e api -m claude-4.5-sonnet)
# ANTHROPIC_API_KEY=sk-ant-...

# Custom OpenAI-compatible endpoint (Ollama, LiteLLM, Azure, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
